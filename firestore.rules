rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Secure rules: Users can only access their own data silo.
     * Access is restricted to the authenticated user whose UID matches the document path.
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    /**
     * @description Public lookup for automation (e.g. WhatsApp bots).
     * This allows the API to find a client across all user accounts by phone number.
     */
    match /users/{userId}/clients/{clientId} {
      allow read: if true; 
    }
  }
}