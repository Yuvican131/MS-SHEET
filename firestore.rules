rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allow full unrestricted access to the 'global-admin' user path.
     * This is required because authentication has been removed and the app uses this fixed ID.
     */
    match /users/global-admin {
      allow read, write: if true;
    }

    match /users/global-admin/{allPaths=**} {
      allow read, write: if true;
    }

    /**
     * @description Allow listing the top-level 'users' and 'clients' collections.
     * This is required for the automation API to search for clients by phone number across the DB.
     */
    match /users {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if true;
      
      match /clients/{clientId} {
        allow read: if true;
      }
      
      // Default rule for other users if they ever sign in via the API or other means
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}