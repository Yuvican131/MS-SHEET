
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Enforce per-user data ownership.
     * Only the logged-in user can access their own data path.
     */
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * @description Allow searching for clients by phone number for WhatsApp automation.
     * The automation bot or API route needs to list users to find the right owner.
     */
    match /users {
      allow list: if request.auth != null;
    }

    /**
     * @description Internal lookup for individual client details.
     */
    match /users/{userId}/clients/{clientId} {
      allow read: if request.auth != null && request.auth.uid == userId; 
    }
  }
}
