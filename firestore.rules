rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Allow full unrestricted access to all documents.
     * This is required because authentication has been removed and the app 
     * operates in a global-admin mode.
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}