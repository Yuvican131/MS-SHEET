rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allow unrestricted access to the 'global-admin' user path.
     * This is required since authentication has been removed and the app uses a fixed ID.
     */
    match /users/global-admin {
      allow read, write: if true;
      
      match /{allPaths=**} {
        allow read, write: if true;
      }
    }

    /**
     * @description Allow listing the top-level 'users' collection.
     * This is required for the automation API to search for clients by phone number.
     */
    match /users {
      allow read: if true;
    }

    /**
     * @description Default rules for any other user IDs (requires authentication).
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}