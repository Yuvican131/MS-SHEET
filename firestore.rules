rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is the 'global-admin' or the authenticated owner.
     */
    function isOwner(userId) {
      return userId == 'global-admin' || (request.auth != null && request.auth.uid == userId);
    }

    /**
     * @description Grants access to all data under a user's path if they are the owner.
     * This covers clients, sheetLogs, declaredNumbers, and any other sub-collections.
     */
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Explicitly allow access to the users collection itself for discovery if needed
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}