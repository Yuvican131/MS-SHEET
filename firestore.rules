rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Allow any authenticated user (including anonymous) to access the main data silo.
     * This ensures the app is "Protected" by the passcode login while fixing permission errors.
     */
    match /users/global-admin/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * @description Public lookup for automation (e.g. WhatsApp bots).
     */
    match /users/{userId}/clients/{clientId} {
      allow read: if true; 
    }
  }
}