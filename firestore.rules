rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Direct access for the fixed 'global-admin' ID.
     * This allows the app to function without Firebase Authentication.
     */
    match /users/global-admin/{allPaths=**} {
      allow read, write: if true;
    }

    /**
     * @description Fallback for any other user IDs (requires authentication).
     */
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Explicitly allow access to the users collection itself for the API search logic
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}